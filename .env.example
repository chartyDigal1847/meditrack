APP_NAME=MediTrack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://meditrack.deoris.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=meditrack_service
DB_USERNAME=root
DB_PASSWORD=

# Main DEORIS identity database. MediTrack does not create or own users.
DEORIS_DB_DRIVER=mysql
DEORIS_DB_HOST=127.0.0.1
DEORIS_DB_PORT=3306
DEORIS_DB_DATABASE=deoris_identity_db
DEORIS_DB_USERNAME=root
DEORIS_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none
SESSION_PATH=/
SESSION_DOMAIN=.deoris.test

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

APP_PORTAL_URL=https://deoris.test
AUTH_SERVICE_URL=https://deoris.test
DEORIS_PORTAL_URL=https://deoris.test
DEORIS_EVENT_HUB_URL=
DEORIS_PORTAL_PUBLIC_KEY=

# SSO Configuration
SSO_SESSION_LIFETIME=120
SSO_EXPIRE_ON_CLOSE=false
SSO_LOGGING=true
SSO_LOG_LEVEL=errors
SSO_LOG_USER_DETAILS=false

MEDITRACK_SERVICE_NAME=MediTrack
MEDITRACK_SERVICE_KEY=meditrack-service
MEDITRACK_EVENT_MODULE=MediTrack
MEDITRACK_SERVICE_URL="${APP_URL}"
MEDITRACK_API_VERSION=v1
MEDITRACK_EVENT_SECRET=change-me-meditrack
MEDITRACK_SEARCH_TOKEN=change-me-meditrack-search
MEDITRACK_REDIS_MEDICAL_EVENTS=medical.events
MEDITRACK_REDIS_CLINIC_NOTIFICATIONS=clinic.notifications
MEDITRACK_REDIS_EMERGENCY_ALERTS=clinic.emergency-alerts
MEDITRACK_QUEUE_MEDICAL=medical
MEDITRACK_QUEUE_NOTIFICATIONS=notifications
MEDITRACK_QUEUE_ALERTS=alerts
MEDITRACK_QUEUE_EVENTS=events

REVERB_APP_ID=meditrack
REVERB_APP_KEY=meditrack-local-key
REVERB_APP_SECRET=meditrack-local-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@meditrack.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
